# =================================================================
# ENVIRONMENT CONFIGURATION
# =================================================================

# Used for Minutes of Meeting (MOM) analysis in Module B Voice Bot logic.
GOOGLE_API_KEY=<apikey>

# Used for High-Speed Transcription in Module B (Smart Secretary).
SARVAM_API_KEY=<apikey>

# --- SYSTEM & HARDWARE SETTINGS ---
# Optional: Helps the Voice Bot find NVIDIA GPU libraries (cuBLAS, cuDNN).
# this path was for us, choose the path correctly for your implementation
LD_LIBRARY_PATH=/opt/python-venvs/project/dev/.venv/lib/python3.12/site-packages/nvidia/cublas/lib:/opt/python-venvs/project/dev/.venv/lib/python3.12/site-packages/nvidia/cudnn/lib

# --- BOT CONFIGURATION ---
# Sets the default voice for the Piper TTS engine.
VOICE_MODEL=en_US-amy-low.onnx
